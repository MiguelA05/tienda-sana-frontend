# Copia este archivo a .env y ajusta valores:
#   copy .env.example .env   (Windows CMD)
#   Copy-Item .env.example .env   (PowerShell)
#
# Rutas alineadas con el backend (AutenticacionController, ClienteController,
# CuentaController, PublicoController). Sin barra final.

AUTH_SERVICE_URL=http://localhost:8080/api/auth
CLIENTE_SERVICE_URL=http://localhost:8080/api/cliente
CUENTA_SERVICE_URL=http://localhost:8080/api/account
PUBLICO_SERVICE_URL=http://localhost:8080/api/public
ADMIN_SERVICE_URL=http://localhost:8080/api/admin
